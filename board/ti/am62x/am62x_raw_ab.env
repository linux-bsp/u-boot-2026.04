#include <env/ti/ti_common.env>

kernel_addr_r=0x90000000
loadaddr=0x82000000
serverip=192.168.18.245
gatewayip=192.168.18.1
ipaddr=192.168.18.246
upk=fw update tftp kernel.itb
upr=fw update tftp rootfs.itb
upb=fw update tftp bootloader.itb
upa=fw update tftp release.itb all
fw_mmcdev=1
fw_parts_a=1M(tiboot3_a),2M(tispl_a),2M(uboot_a),64K(meta0),64K(meta1),1920K(env_area)
fw_parts_b=1M(tiboot3_b),2M(tispl_b),2M(uboot_b),4M(reserved1)
fw_parts_os=24M(kernel_a),24M(kernel_b),128M(rootfs_a),128M(rootfs_b),-(data)
fw_set_root=
	if test "${fw_rootfs_slot}" = "a"; then
		setenv fw_rootpart 13;
	else
		setenv fw_rootpart 14;
	fi
fw_load_kernel=
	mmc dev ${fw_mmcdev} &&
	setexpr fw_kernel_lba ${fw_kernel_offset} / 0x200 &&
	setexpr fw_kernel_blocks ${fw_kernel_size} / 0x200 &&
	mmc read ${kernel_addr_r} ${fw_kernel_lba} ${fw_kernel_blocks}
fw_set_bootargs=
	setenv bootargs console=ttyS2,115200n8
	earlycon=ns16550a,mmio32,0x02800000
	root=/dev/mmcblk1p${fw_rootpart} rootfstype=squashfs ro rootwait
	blkdevparts=mmcblk1:${fw_parts_a},${fw_parts_b},${fw_parts_os}
	fw.deployment=${fw_deployment}
fw_apply_confirm=
	if test -n "${fw_confirm}"; then
		fw mark-good ${fw_confirm} &&
		setenv fw_confirm &&
		saveenv;
	else
		true;
	fi
fw_boot=
	run fw_apply_confirm &&
	fw select &&
	run fw_set_root &&
	run fw_set_bootargs &&
	run fw_load_kernel &&
	bootm ${kernel_addr_r}
bootcmd=run fw_boot
