#include <env/ti/ti_common.env>

kernel_addr_r=0x82000000
loadaddr=0x82000000
fu_mmcdev=1
fu_parts_a=1M(tiboot3_a),2M(tispl_a),2M(uboot_a),64K(meta0),64K(meta1),1920K(reserved0)
fu_parts_b=1M(tiboot3_b),2M(tispl_b),2M(uboot_b),4M(reserved1)
fu_parts_os=24M(kernel_a),24M(kernel_b),128M(rootfs_a),128M(rootfs_b),-(data)
fu_set_root=
	if test "${fu_rootfs_slot}" = "a"; then
		setenv fu_rootpart 13;
	else
		setenv fu_rootpart 14;
	fi
fu_load_kernel=
	mmc dev ${fu_mmcdev} &&
	setexpr fu_kernel_lba ${fu_kernel_offset} / 0x200 &&
	setexpr fu_kernel_blocks ${fu_kernel_size} / 0x200 &&
	mmc read ${kernel_addr_r} ${fu_kernel_lba} ${fu_kernel_blocks}
fu_set_bootargs=
	setenv bootargs console=ttyS2,115200n8
	earlycon=ns16550a,mmio32,0x02800000
	root=/dev/mmcblk1p${fu_rootpart} rootfstype=squashfs ro rootwait
	blkdevparts=mmcblk1:${fu_parts_a},${fu_parts_b},${fu_parts_os}
	fu.deployment=${fu_deployment}
fu_boot=
	fu select &&
	run fu_set_root &&
	run fu_set_bootargs &&
	run fu_load_kernel &&
	bootm ${kernel_addr_r}
bootcmd=run fu_boot
