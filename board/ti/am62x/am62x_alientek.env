kernel_comp_addr_r=0x90000000
kernel_comp_size=0x01700000
bootargs=console=ttyS2,115200n8 earlycon=ns16550a,mmio32,0x02800000 root=/dev/mmcblk1p7 rootfstype=squashfs ro rootwait blkdevparts=mmcblk1:1M(tiboot3),2M(tispl),2M(uboot),2M(uboot-env),23M(kernel),1M(dtb),-(rootfs)
bootcmd=
	mmc dev 1 &&
	mmc read 0x82000000 0x3800 0xb800 &&
	mmc read 0x88000000 0xf000 0x800 &&
	booti 0x82000000 - 0x88000000
